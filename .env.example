# Backend API URL
# For local development: http://localhost:3000
# For production: https://zonal-megen-falkyblinders-09833153.koyeb.app
# 
# This variable is OPTIONAL — the app auto-detects the correct URL:
#   - Development builds automatically use http://localhost:3000
#   - Production builds automatically use the Koyeb backend URL
# Set this to override the automatic detection.
#
# CORS REQUIREMENTS:
# - Backend must include frontend origin in Access-Control-Allow-Origin
# - Backend must NOT use wildcard (*) when credentials are enabled
# - Backend must allow: Access-Control-Allow-Credentials: true
VITE_API_URL=https://zonal-megen-falkyblinders-09833153.koyeb.app

# Frontend URL (for OAuth redirects and email verification links)
# For local development: http://localhost:8080
# For production: https://aurikrex.tech
#
# This should match the origin that the backend allows for CORS
VITE_FRONTEND_URL=https://aurikrex.tech

# Application name (for branding)
VITE_APP_NAME=AurikrexAcademy

# =============================================================================
# ENVIRONMENT VARIABLES CHECKLIST
# =============================================================================
# When deploying to production, ensure these are set in your project settings:
#
# Optional (auto-detected if not set):
#   VITE_API_URL=https://zonal-megen-falkyblinders-09833153.koyeb.app
#   VITE_FRONTEND_URL=https://aurikrex.tech
#
# Backend must have these configured (not frontend env vars):
#   - ALLOWED_ORIGINS must include your frontend domain
#   - OAuth callback URLs must point to backend
#   - GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#   - MICROSOFT_CLIENT_ID, MICROSOFT_CLIENT_SECRET, MICROSOFT_TENANT_ID
#   - GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET (optional)
#
# =============================================================================
# TROUBLESHOOTING "Failed to fetch" ERRORS
# =============================================================================
# 1. Verify VITE_API_URL is set correctly (or auto-detection is working)
# 2. Ensure backend CORS allows your frontend origin
# 3. Check that backend is running and accessible
# 4. Verify HTTPS is used in production
# 5. Check browser console for detailed error messages
# =============================================================================
